{
  "apiVersion": "sentinelflow.io/v1alpha1",
  "kind": "ToolManifest",
  "metadata": {
    "name": "invalid-synthetic-validator"
  },
  "spec": {
    "displayName": "Invalid Synthetic Validator",
    "version": "0.1.0",
    "capabilities": [
      {
        "name": "unapproved-high-risk-declaration",
        "description": "Fixture deliberately missing mandatory approval",
        "risk": "high",
        "requiresApproval": false
      }
    ],
    "runtime": {
      "mode": "process",
      "entrypoint": "runner/example",
      "args": [],
      "environmentAllowlist": [],
      "timeoutSeconds": 30,
      "outputLimitBytes": 1048576
    },
    "parser": {
      "mode": "builtin",
      "name": "example-echo-v1"
    },
    "inputSchema": "schemas/v1alpha1/does-not-exist.schema.json",
    "outputSchema": "schemas/v1alpha1/tool-output.schema.json"
  },
  "extensions": {}
}
