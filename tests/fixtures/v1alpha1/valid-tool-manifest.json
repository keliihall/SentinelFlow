{
  "apiVersion": "sentinelflow.io/v1alpha1",
  "kind": "ToolManifest",
  "metadata": {
    "name": "synthetic-validator",
    "labels": {
      "sentinelflow.io/example": "true"
    }
  },
  "spec": {
    "displayName": "Synthetic Validator",
    "version": "0.1.0",
    "capabilities": [
      {
        "name": "fixture-validation",
        "description": "Validates synthetic fixture structure only",
        "risk": "low",
        "requiresApproval": false
      },
      {
        "name": "approved-high-risk-declaration",
        "description": "Exercises approval metadata without operational behavior",
        "risk": "high",
        "requiresApproval": true
      }
    ],
    "runtime": {
      "mode": "process",
      "entrypoint": "runner/example",
      "args": [],
      "environmentAllowlist": [],
      "timeoutSeconds": 30,
      "outputLimitBytes": 1048576
    },
    "parser": {
      "mode": "builtin",
      "name": "example-echo-v1"
    },
    "inputSchema": "schemas/v1alpha1/tool-input.schema.json",
    "outputSchema": "schemas/v1alpha1/tool-output.schema.json"
  },
  "extensions": {
    "sentinelflow.io/fixture": true
  }
}
