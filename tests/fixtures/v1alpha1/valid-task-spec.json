{
  "apiVersion": "sentinelflow.io/v1alpha1",
  "kind": "TaskSpec",
  "metadata": {
    "name": "synthetic-validation-task"
  },
  "spec": {
    "authorizationScope": "fixture:local-only",
    "targets": [
      {
        "name": "fixture-one",
        "input": {
          "message": "safe local data"
        }
      }
    ],
    "steps": [
      {
        "name": "echo",
        "toolRef": "example-echo",
        "capability": "echo"
      }
    ],
    "policy": {
      "allowedTargets": [
        "fixture-one"
      ],
      "approveHighRisk": false,
      "timeoutSeconds": 5
    }
  },
  "extensions": {}
}
