{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Port Probe Plus Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["context", "target", "inputs", "options", "policy"],
  "properties": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "run_id", "operator", "workspace", "authorization_scope"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "run_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "operator": {"type": "string", "minLength": 1, "maxLength": 128},
        "workspace": {"type": "string", "minLength": 1, "maxLength": 128},
        "authorization_scope": {"type": "string", "minLength": 3, "maxLength": 256}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value", "metadata"],
      "properties": {
        "type": {"const": "domain"},
        "value": {"type": "string", "minLength": 3, "maxLength": 253},
        "metadata": {"type": "object", "additionalProperties": true}
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["addresses", "findings"],
      "properties": {
        "addresses": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "anyOf": [
              {"type": "string", "minLength": 3, "maxLength": 64},
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["address"],
                "properties": {
                  "address": {"type": "string", "minLength": 3, "maxLength": 64},
                  "hostnames": {"type": "array", "maxItems": 16, "items": {"type": "string"}}
                }
              }
            ]
          }
        },
        "findings": {"type": "array", "maxItems": 10000, "items": {"type": "object", "additionalProperties": true}}
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "passive_intel", "active", "merge", "output", "execution_profile"],
      "properties": {
        "mode": {"type": "string", "enum": ["fixture", "dry_run", "passive_intel", "active_tcp_connect", "hybrid"]},
        "passive_intel": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "sources", "allow_missing_secrets", "api_timeout_seconds", "api_rate_limit_per_second", "max_queries", "local_cache_file"],
          "properties": {
            "enabled": {"type": "boolean"},
            "sources": {"type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "enum": ["fixture", "local_cache", "fofa", "shodan"]}},
            "allow_missing_secrets": {"type": "boolean"},
            "api_timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 30},
            "api_rate_limit_per_second": {"type": "integer", "minimum": 1, "maximum": 10},
            "max_queries": {"type": "integer", "minimum": 0, "maximum": 1000},
            "local_cache_file": {"$ref": "#/definitions/SafeRelativePath"},
            "fixture_file": {"$ref": "#/definitions/SafeRelativePath"}
          }
        },
        "active": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "probe_engine", "port_profile", "ports", "timeout_seconds", "concurrency", "rate_limit_per_second", "max_targets", "max_ports"],
          "properties": {
            "enabled": {"type": "boolean"},
            "probe_engine": {"type": "string", "enum": ["tcp_connect"]},
            "port_profile": {"type": "string", "enum": ["web", "minimal", "custom"]},
            "ports": {"type": "array", "maxItems": 100, "uniqueItems": true, "items": {"type": "integer", "minimum": 1, "maximum": 65535}},
            "timeout_seconds": {"type": "number", "minimum": 0.2, "maximum": 10},
            "concurrency": {"type": "integer", "minimum": 1, "maximum": 20},
            "rate_limit_per_second": {"type": "integer", "minimum": 1, "maximum": 20},
            "max_targets": {"type": "integer", "minimum": 1, "maximum": 1000},
            "max_ports": {"type": "integer", "minimum": 1, "maximum": 100}
          }
        },
        "merge": {
          "type": "object",
          "additionalProperties": false,
          "required": ["deduplicate", "conflict_policy", "mark_source_disagreement", "confidence_strategy", "stale_after_days"],
          "properties": {
            "deduplicate": {"type": "boolean"},
            "conflict_policy": {"type": "string", "enum": ["preserve_all_sources"]},
            "mark_source_disagreement": {"type": "boolean"},
            "confidence_strategy": {"type": "string", "enum": ["weighted_sources"]},
            "stale_after_days": {"type": "integer", "minimum": 1, "maximum": 3650}
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["include_closed", "include_filtered", "include_source_details", "include_conflicts"],
          "properties": {
            "include_closed": {"type": "boolean"},
            "include_filtered": {"type": "boolean"},
            "include_source_details": {"type": "boolean"},
            "include_conflicts": {"type": "boolean"}
          }
        },
        "execution_profile": {"type": "string", "enum": ["fixture", "passive_intel", "active_safe", "authorized_assessment"]}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allow_active_verify", "allow_high_risk"],
      "properties": {
        "allow_active_verify": {"type": "boolean"},
        "allow_high_risk": {"const": false}
      }
    }
  },
  "definitions": {
    "SafeRelativePath": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.)(?!.*\\x00).+$"}
  }
}
