{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Port Probe Plus Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "target", "mode", "results", "source_status", "summary", "errors", "safety"],
  "properties": {
    "source": {"const": "port-probe-plus"},
    "target": {"type": "object", "additionalProperties": true},
    "mode": {"type": "string", "enum": ["fixture", "dry_run", "passive_intel", "active_tcp_connect", "hybrid"]},
    "results": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "address", "port", "protocol", "state", "sources", "source_agreement", "confidence", "evidence"],
        "properties": {
          "type": {"const": "port_result"},
          "address": {"type": "string"},
          "port": {"type": "integer", "minimum": 1, "maximum": 65535},
          "protocol": {"type": "string", "enum": ["tcp", "udp"]},
          "state": {"type": "string"},
          "sources": {"type": "array", "items": {"type": "string"}},
          "source_agreement": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "source_status": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "summary": {"type": "object", "additionalProperties": true},
    "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "safety": {"type": "object", "additionalProperties": true}
  }
}
