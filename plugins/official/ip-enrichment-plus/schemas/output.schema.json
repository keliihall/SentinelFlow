{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IP Enrichment Plus Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "target", "mode", "results", "source_status", "summary", "errors", "safety"],
  "properties": {
    "source": {"const": "ip-enrichment-plus"},
    "target": {"type": "object", "additionalProperties": true},
    "mode": {"type": "string", "enum": ["fixture", "dry_run", "local_cache", "provider_lookup", "hybrid"]},
    "results": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "ip", "ip_version", "classification", "is_public", "sources", "confidence", "evidence"],
        "properties": {
          "type": {"const": "ip_enrichment_result"},
          "ip": {"type": "string"},
          "ip_version": {"type": "integer", "enum": [4, 6]},
          "classification": {"type": "string"},
          "is_public": {"type": "boolean"},
          "asn": {"type": ["integer", "null"], "minimum": 0},
          "organization": {"type": ["string", "null"]},
          "isp": {"type": ["string", "null"]},
          "geo": {"type": "object", "additionalProperties": true},
          "cloud": {"type": "object", "additionalProperties": true},
          "cdn_waf": {"type": "object", "additionalProperties": true},
          "sources": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "source_status": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "summary": {"type": "object", "additionalProperties": true},
    "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "safety": {"type": "object", "additionalProperties": true}
  }
}
