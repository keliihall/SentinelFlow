{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "crt.sh Subdomain Plus Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "domain", "mode", "findings", "certificates", "source_status", "summary", "errors", "safety"],
  "properties": {
    "source": {"const": "crtsh-subdomain-plus"},
    "domain": {"type": "string", "minLength": 3, "maxLength": 253},
    "mode": {"type": "string", "enum": ["fixture", "dry_run", "local_cache", "api_lookup", "hybrid"]},
    "findings": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "domain", "subdomain", "sources", "confidence", "evidence"],
        "properties": {
          "type": {"const": "subdomain_finding"},
          "domain": {"type": "string"},
          "subdomain": {"type": "string"},
          "sources": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "certificates": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "domain", "common_name", "san_names", "sources", "confidence", "evidence"],
        "properties": {
          "type": {"const": "certificate_asset"},
          "domain": {"type": "string"},
          "common_name": {"type": ["string", "null"]},
          "san_names": {"type": "array", "items": {"type": "string"}},
          "sources": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "source_status": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "summary": {"type": "object", "additionalProperties": true},
    "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "safety": {"type": "object", "additionalProperties": true}
  }
}
