{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Web Fingerprint Plus Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "target", "mode", "results", "source_status", "summary", "errors", "safety"],
  "properties": {
    "source": {"const": "web-fingerprint-plus"},
    "target": {"type": "object", "additionalProperties": true},
    "mode": {"type": "string", "enum": ["fixture", "dry_run", "passive_intel", "from_http_probe"]},
    "results": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "url", "technology", "category", "confidence", "sources", "signals", "evidence"],
        "properties": {
          "type": {"const": "web_fingerprint_result"},
          "url": {"type": "string"},
          "technology": {"type": "string"},
          "category": {"type": "string"},
          "version": {"type": ["string", "null"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "sources": {"type": "array", "items": {"type": "string"}},
          "signals": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
          "evidence": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "source_status": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "summary": {"type": "object", "additionalProperties": true},
    "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "safety": {"type": "object", "additionalProperties": true}
  }
}
