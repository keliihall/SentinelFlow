{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Subdomain Discovery Plus Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source",
    "domain",
    "mode",
    "run_context",
    "findings",
    "candidates",
    "invalid_observations",
    "source_status",
    "summary",
    "errors",
    "safety"
  ],
  "properties": {
    "source": {"const": "subdomain-discovery-plus"},
    "domain": {"$ref": "#/definitions/Domain"},
    "mode": {"$ref": "#/definitions/Mode"},
    "run_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "input_target", "authorization_scope", "synthetic_fixture", "real_scan", "planned_sources"],
      "properties": {
        "mode": {"$ref": "#/definitions/Mode"},
        "input_target": {"$ref": "#/definitions/Domain"},
        "authorization_scope": {"type": "string", "minLength": 3, "maxLength": 256},
        "synthetic_fixture": {"type": "boolean"},
        "real_scan": {"type": "boolean"},
        "planned_sources": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 10000,
      "items": {"$ref": "#/definitions/ConfirmedSubdomain"}
    },
    "candidates": {
      "type": "array",
      "maxItems": 10000,
      "items": {"$ref": "#/definitions/CandidateSubdomain"}
    },
    "invalid_observations": {
      "type": "array",
      "maxItems": 10000,
      "items": {"$ref": "#/definitions/InvalidObservation"}
    },
    "source_status": {
      "type": "array",
      "maxItems": 32,
      "items": {"$ref": "#/definitions/SourceStatus"}
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "mode",
        "confirmed_count",
        "candidate_count",
        "invalid_count",
        "source_count",
        "generated_candidate_count",
        "finding_count",
        "active_queries",
        "wildcard_detected",
        "wildcard_filtered_count",
        "errors"
      ],
      "properties": {
        "domain": {"$ref": "#/definitions/Domain"},
        "mode": {"$ref": "#/definitions/Mode"},
        "target": {"$ref": "#/definitions/Domain"},
        "authorization_scope": {"type": "string", "minLength": 3, "maxLength": 256},
        "synthetic_fixture": {"type": "boolean"},
        "real_scan": {"type": "boolean"},
        "planned_sources": {"type": "array", "items": {"type": "string"}},
        "confirmed_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "candidate_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "invalid_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "source_count": {"type": "integer", "minimum": 0, "maximum": 32},
        "candidate_observation_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "invalid_observation_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "generated_candidate_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "finding_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "active_queries": {"type": "integer", "minimum": 0, "maximum": 100000},
        "wildcard_detected": {"type": "boolean"},
        "wildcard_filtered_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "errors": {"type": "array", "maxItems": 50, "items": {"type": "string", "minLength": 1, "maxLength": 512}}
      }
    },
    "errors": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "details"],
        "properties": {
          "code": {"type": "string", "minLength": 1, "maxLength": 128},
          "message": {"type": "string", "minLength": 1, "maxLength": 512},
          "field": {"type": "string", "minLength": 1, "maxLength": 256},
          "details": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type_domain_only",
        "authorization_scope_required",
        "active_policy_allowed",
        "active_dns_queries",
        "dictionary_candidates",
        "brute_force_attempts",
        "port_scan_attempts",
        "exploit_attempts"
      ],
      "properties": {
        "target_type_domain_only": {"const": true},
        "authorization_scope_required": {"const": true},
        "active_policy_allowed": {"type": "boolean"},
        "active_dns_queries": {"type": "integer", "minimum": 0, "maximum": 100000},
        "dictionary_candidates": {"type": "integer", "minimum": 0, "maximum": 10000},
        "brute_force_attempts": {"const": 0},
        "port_scan_attempts": {"const": 0},
        "exploit_attempts": {"const": 0}
      }
    }
  },
  "definitions": {
    "Domain": {"type": "string", "minLength": 3, "maxLength": 253},
    "Mode": {"type": "string", "enum": ["fixture", "dry_run", "passive_intel", "active_dictionary", "hybrid"]},
    "Record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "value", "address_class", "public_routable"],
      "properties": {
        "record_type": {"type": "string", "enum": ["A", "AAAA", "CNAME"]},
        "value": {"type": "string", "minLength": 1, "maxLength": 253},
        "address_class": {"type": "string", "minLength": 1, "maxLength": 64},
        "public_routable": {"type": "boolean"}
      }
    },
    "Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {"type": "string", "minLength": 1, "maxLength": 512},
        "items": {"type": "array", "maxItems": 32, "items": {"type": "object", "additionalProperties": true}}
      }
    },
    "SourceDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "source_type", "resolved", "records", "confidence"],
      "properties": {
        "source": {"type": "string"},
        "source_type": {"type": "string", "enum": ["fixture", "passive_intel", "active_verify"]},
        "resolved": {"type": "boolean"},
        "records": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "ConfirmedSubdomain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type", "status", "domain", "subdomain", "source", "sources", "source_details",
        "resolved", "confirmed", "public_routable", "record_type", "addresses", "records",
        "confidence", "synthetic", "synthetic_fixture", "real_scan", "evidence", "raw"
      ],
      "properties": {
        "type": {"const": "subdomain_result"},
        "status": {"const": "confirmed"},
        "domain": {"$ref": "#/definitions/Domain"},
        "subdomain": {"$ref": "#/definitions/Domain"},
        "source": {"type": "string"},
        "sources": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"type": "string"}},
        "source_details": {"type": "array", "items": {"$ref": "#/definitions/SourceDetail"}},
        "resolved": {"type": "boolean"},
        "confirmed": {"const": true},
        "public_routable": {"type": "boolean"},
        "record_type": {"type": "string", "enum": ["A", "AAAA", "CNAME", "unknown"]},
        "addresses": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string"}},
        "records": {"type": "array", "maxItems": 64, "items": {"$ref": "#/definitions/Record"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "synthetic": {"type": "boolean"},
        "synthetic_fixture": {"type": "boolean"},
        "real_scan": {"type": "boolean"},
        "evidence": {"$ref": "#/definitions/Evidence"},
        "raw": {"type": "object", "additionalProperties": true}
      }
    },
    "CandidateSubdomain": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "status", "domain", "subdomain", "sources", "resolved", "confirmed", "confidence", "evidence"],
      "properties": {
        "type": {"const": "subdomain_candidate"},
        "status": {"type": "string", "enum": ["candidate_unresolved", "candidate_unconfirmed", "nxdomain", "timeout", "servfail", "query_error", "wildcard_filtered"]},
        "domain": {"$ref": "#/definitions/Domain"},
        "subdomain": {"$ref": "#/definitions/Domain"},
        "sources": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "resolved": {"type": "boolean"},
        "confirmed": {"const": false},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence": {"$ref": "#/definitions/Evidence"}
      }
    },
    "InvalidObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "status", "domain", "subdomain", "records", "confidence", "synthetic", "real_scan", "evidence"],
      "properties": {
        "type": {"const": "invalid_observation"},
        "status": {"enum": ["invalid_special_address", "wildcard_filtered", "invalid_domain"]},
        "domain": {"$ref": "#/definitions/Domain"},
        "subdomain": {"$ref": "#/definitions/Domain"},
        "records": {"type": "array", "items": {"$ref": "#/definitions/Record"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "synthetic": {"type": "boolean"},
        "real_scan": {"type": "boolean"},
        "evidence": {"$ref": "#/definitions/Evidence"}
      }
    },
    "SourceStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "source", "enabled", "status", "result_count", "error"],
      "properties": {
        "type": {"const": "source_status"},
        "source": {"type": "string", "minLength": 1, "maxLength": 64},
        "enabled": {"type": "boolean"},
        "status": {"type": "string", "enum": ["ok", "empty", "dry_run", "error", "skipped_disabled", "skipped_missing_secret", "skipped_not_configured", "skipped_not_implemented"]},
        "result_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "error": {"type": ["string", "null"], "maxLength": 512}
      }
    }
  }
}
