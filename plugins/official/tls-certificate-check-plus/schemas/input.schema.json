{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLS Certificate Check Plus Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["context", "target", "inputs", "options", "policy"],
  "properties": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "run_id", "operator", "workspace", "authorization_scope"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "run_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "operator": {"type": "string", "minLength": 1, "maxLength": 128},
        "workspace": {"type": "string", "minLength": 1, "maxLength": 128},
        "authorization_scope": {"type": "string", "minLength": 3, "maxLength": 256}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value", "metadata"],
      "properties": {
        "type": {"const": "domain"},
        "value": {"type": "string", "minLength": 3, "maxLength": 253},
        "metadata": {"type": "object", "additionalProperties": true}
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoints", "findings"],
      "properties": {
        "endpoints": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["host"],
            "properties": {
              "host": {"type": "string", "minLength": 1, "maxLength": 253},
              "port": {"type": "integer", "minimum": 1, "maximum": 65535},
              "server_name": {"type": "string", "maxLength": 253}
            }
          }
        },
        "findings": {"type": "array", "maxItems": 10000, "items": {"type": "object", "additionalProperties": true}}
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "passive_intel", "active", "checks", "merge", "output", "execution_profile"],
      "properties": {
        "mode": {"type": "string", "enum": ["fixture", "dry_run", "passive_intel", "active_tls", "hybrid"]},
        "passive_intel": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "sources", "local_cache_file"],
          "properties": {
            "enabled": {"type": "boolean"},
            "sources": {"type": "array", "minItems": 1, "maxItems": 2, "uniqueItems": true, "items": {"type": "string", "enum": ["fixture", "local_cache"]}},
            "local_cache_file": {"$ref": "#/definitions/SafeRelativePath"},
            "fixture_file": {"$ref": "#/definitions/SafeRelativePath"}
          }
        },
        "active": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "timeout_seconds", "concurrency", "rate_limit_per_second", "max_endpoints"],
          "properties": {
            "enabled": {"type": "boolean"},
            "timeout_seconds": {"type": "number", "minimum": 0.2, "maximum": 10},
            "concurrency": {"type": "integer", "minimum": 1, "maximum": 20},
            "rate_limit_per_second": {"type": "integer", "minimum": 1, "maximum": 20},
            "max_endpoints": {"type": "integer", "minimum": 1, "maximum": 1000}
          }
        },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expiry_warning_days", "include_san_assets", "include_chain_summary"],
          "properties": {
            "expiry_warning_days": {"type": "integer", "minimum": 1, "maximum": 365},
            "include_san_assets": {"type": "boolean"},
            "include_chain_summary": {"type": "boolean"}
          }
        },
        "merge": {
          "type": "object",
          "additionalProperties": false,
          "required": ["deduplicate", "confidence_strategy"],
          "properties": {
            "deduplicate": {"type": "boolean"},
            "confidence_strategy": {"type": "string", "enum": ["weighted_sources"]}
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["include_source_details"],
          "properties": {
            "include_source_details": {"type": "boolean"}
          }
        },
        "execution_profile": {"type": "string", "enum": ["fixture", "passive_intel", "active_safe", "lab"]}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allow_active_verify", "allow_high_risk"],
      "properties": {
        "allow_active_verify": {"type": "boolean"},
        "allow_high_risk": {"const": false}
      }
    }
  },
  "definitions": {
    "SafeRelativePath": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.)(?!.*\\x00).+$"}
  }
}
