{
  "context": {
    "task_id": "task-censys-api",
    "run_id": "run-censys-api",
    "operator": "fixture-operator",
    "workspace": "fixture-workspace",
    "authorization_scope": "fixture:local-only"
  },
  "target": {
    "type": "domain",
    "value": "example.com",
    "metadata": {}
  },
  "options": {
    "mode": "api_lookup",
    "lookup": {
      "scope": "domain",
      "max_results": 100,
      "include_certificate": true,
      "include_names": true,
      "include_service_fingerprint": true
    },
    "local_cache": {
      "enabled": false,
      "cache_file": "examples/cache.empty.json",
      "fixture_file": "examples/fixture.censys.example.com.json"
    },
    "provider": {
      "enabled": true,
      "allow_missing_secret": true,
      "timeout_seconds": 10,
      "rate_limit_per_second": 1
    },
    "merge": {
      "deduplicate": true,
      "confidence_strategy": "weighted_sources"
    },
    "output": {
      "include_certificate": true,
      "include_names": true,
      "include_service_fingerprint": true,
      "include_source_details": true
    },
    "execution_profile": "passive_intel"
  },
  "policy": {
    "allow_active_verify": false,
    "allow_high_risk": false
  }
}
