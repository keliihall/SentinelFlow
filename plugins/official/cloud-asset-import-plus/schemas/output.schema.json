{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cloud Asset Import Plus Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "target", "mode", "results", "source_status", "summary", "errors", "safety"],
  "properties": {
    "source": {"const": "cloud-asset-import-plus"},
    "target": {"type": "object", "additionalProperties": true},
    "mode": {"type": "string", "enum": ["fixture", "dry_run", "local_file"]},
    "results": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "provider", "resource_type", "resource_id", "name", "scope_id", "region", "internet_exposed", "risk", "sources", "confidence", "evidence"],
        "properties": {
          "type": {"const": "cloud_asset_result"},
          "provider": {"type": "string", "enum": ["alibaba", "tencent", "huawei", "aws", "azure"]},
          "resource_type": {"type": "string", "enum": ["compute", "public_ip", "load_balancer", "security_group", "dns", "object_storage", "waf", "cdn"]},
          "resource_id": {"type": "string"},
          "name": {"type": "string"},
          "scope_id": {"type": "string"},
          "region": {"type": "string"},
          "status": {"type": ["string", "null"]},
          "public_ips": {"type": "array", "items": {"type": "string"}},
          "private_ips": {"type": "array", "items": {"type": "string"}},
          "dns_names": {"type": "array", "items": {"type": "string"}},
          "internet_exposed": {"type": "boolean"},
          "exposure_reasons": {"type": "array", "items": {"type": "string"}},
          "risk": {"type": "string", "enum": ["info", "low", "medium", "high"]},
          "sources": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "source_status": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "summary": {"type": "object", "additionalProperties": true},
    "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "safety": {"type": "object", "additionalProperties": true}
  }
}
