{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DNS Resolve Plus Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "target", "mode", "record_types", "observations", "results", "source_status", "summary", "errors", "safety"],
  "properties": {
    "source": {"const": "dns-resolve-plus"},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {"type": {"const": "domain"}, "value": {"type": "string", "minLength": 3, "maxLength": 253}}
    },
    "mode": {"type": "string", "enum": ["fixture", "dry_run", "passive_intel", "active", "hybrid"]},
    "record_types": {"type": "array", "minItems": 1, "maxItems": 6, "items": {"type": "string"}},
    "observations": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/definitions/Observation"}},
    "results": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/definitions/Result"}},
    "source_status": {"type": "array", "maxItems": 50, "items": {"$ref": "#/definitions/SourceStatus"}},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain_count", "record_types", "observation_count", "result_count", "passive_sources", "active_enabled", "estimated_api_queries", "estimated_dns_queries", "requires_active_verify", "requires_high_risk", "requires_approval", "source_status_count", "error_count"],
      "properties": {
        "domain_count": {"type": "integer", "minimum": 0, "maximum": 1000},
        "record_types": {"type": "array", "maxItems": 6, "items": {"type": "string"}},
        "observation_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "result_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "invalid_special_address_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "public_routable_result_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "valid_for_port_probe_count": {"type": "integer", "minimum": 0, "maximum": 10000},
        "passive_sources": {"type": "array", "maxItems": 4, "items": {"type": "string"}},
        "active_enabled": {"type": "boolean"},
        "estimated_api_queries": {"type": "integer", "minimum": 0, "maximum": 10000},
        "estimated_dns_queries": {"type": "integer", "minimum": 0, "maximum": 100000},
        "requires_active_verify": {"type": "boolean"},
        "requires_high_risk": {"type": "boolean"},
        "requires_approval": {"type": "boolean"},
        "source_status_count": {"type": "integer", "minimum": 0, "maximum": 50},
        "error_count": {"type": "integer", "minimum": 0, "maximum": 50}
      }
    },
    "errors": {"type": "array", "maxItems": 50, "items": {"$ref": "#/definitions/Error"}},
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "required": ["target_type_domain_only", "authorization_scope_required", "active_policy_allowed", "high_risk_policy_allowed", "active_dns_queries", "external_api_queries", "shell_commands", "exploit_attempts"],
      "properties": {
        "target_type_domain_only": {"const": true},
        "authorization_scope_required": {"const": true},
        "active_policy_allowed": {"type": "boolean"},
        "high_risk_policy_allowed": {"type": "boolean"},
        "active_dns_queries": {"type": "integer", "minimum": 0, "maximum": 100000},
        "external_api_queries": {"type": "integer", "minimum": 0, "maximum": 10000},
        "shell_commands": {"const": 0},
        "exploit_attempts": {"const": 0}
      }
    }
  },
  "definitions": {
    "Observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "record_type", "value", "ttl", "source", "source_type", "observed_at", "source_updated_at", "confidence", "evidence"],
      "properties": {
        "domain": {"type": "string", "minLength": 3, "maxLength": 253},
        "record_type": {"type": "string", "enum": ["A", "AAAA", "CNAME", "MX", "NS", "TXT"]},
        "value": {"type": "string", "minLength": 1, "maxLength": 512},
        "ttl": {"type": ["integer", "null"], "minimum": 0, "maximum": 2147483647},
        "source": {"type": "string", "enum": ["fixture", "local_cache", "passive_dns_cache", "external_dns_intel", "system_resolver", "public_resolver", "authoritative_trace"]},
        "source_type": {"type": "string", "enum": ["fixture", "passive_intel", "active"]},
        "observed_at": {"type": "string", "minLength": 1, "maxLength": 64},
        "source_updated_at": {"type": ["string", "null"], "maxLength": 64},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence": {"$ref": "#/definitions/Evidence"}
      }
    },
    "Result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "domain", "record_type", "value", "ttl", "resolved", "status", "address_class", "public_routable", "valid_for_port_probe", "sources", "source_details", "source_count", "source_agreement", "conflict", "conflict_reason", "observed_at", "stale", "confidence", "confidence_strategy", "risk_level", "evidence"],
      "properties": {
        "type": {"const": "dns_result"},
        "domain": {"type": "string", "minLength": 3, "maxLength": 253},
        "record_type": {"type": "string", "enum": ["A", "AAAA", "CNAME", "MX", "NS", "TXT"]},
        "value": {"type": ["string", "null"], "maxLength": 512},
        "ttl": {"type": ["integer", "null"], "minimum": 0, "maximum": 2147483647},
        "resolved": {"type": "boolean"},
        "status": {"type": "string", "enum": ["resolved", "unresolved", "invalid_special_address"]},
        "address_class": {
          "type": "string",
          "enum": [
            "public",
            "private",
            "loopback",
            "link_local",
            "multicast",
            "reserved",
            "documentation",
            "benchmark",
            "unspecified",
            "shared_address_space",
            "unique_local_ipv6",
            "ipv4_mapped_public",
            "ipv4_mapped_private",
            "ipv4_mapped_loopback",
            "ipv4_mapped_link_local",
            "ipv4_mapped_multicast",
            "ipv4_mapped_reserved",
            "ipv4_mapped_documentation",
            "ipv4_mapped_benchmark",
            "ipv4_mapped_unspecified",
            "ipv4_mapped_shared_address_space",
            "invalid",
            "not_applicable"
          ]
        },
        "public_routable": {"type": "boolean"},
        "valid_for_port_probe": {"type": "boolean"},
        "sources": {"type": "array", "maxItems": 7, "uniqueItems": true, "items": {"type": "string"}},
        "source_details": {"type": "array", "maxItems": 32, "items": {"$ref": "#/definitions/SourceDetail"}},
        "source_count": {"type": "integer", "minimum": 0, "maximum": 7},
        "source_agreement": {"type": "string", "enum": ["consistent", "passive_only", "active_only", "conflict", "stale_passive", "unresolved", "unknown"]},
        "conflict": {"type": "boolean"},
        "conflict_reason": {"type": ["string", "null"], "maxLength": 128},
        "observed_at": {"type": ["string", "null"], "maxLength": 64},
        "stale": {"type": "boolean"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence_strategy": {"type": "string", "enum": ["weighted_sources"]},
        "risk_level": {"type": "string", "enum": ["low", "medium"]},
        "evidence": {"$ref": "#/definitions/Evidence"}
      }
    },
    "SourceDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "source_type", "observed_at", "source_updated_at", "confidence", "stale", "evidence"],
      "properties": {
        "source": {"type": "string"},
        "source_type": {"type": "string"},
        "observed_at": {"type": "string"},
        "source_updated_at": {"type": ["string", "null"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "stale": {"type": "boolean"},
        "evidence": {"$ref": "#/definitions/Evidence"}
      }
    },
    "SourceStatus": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source", "status", "message", "query_count"],
      "properties": {
        "source": {"type": "string", "minLength": 1, "maxLength": 128},
        "status": {"type": "string", "enum": ["ok", "error", "skipped_missing_secret", "skipped_not_implemented", "skipped_policy_denied"]},
        "message": {"type": "string", "minLength": 1, "maxLength": 512},
        "query_count": {"type": "integer", "minimum": 0, "maximum": 100000}
      }
    },
    "Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "items"],
      "properties": {
        "summary": {"type": "string", "minLength": 1, "maxLength": 512},
        "items": {"type": "array", "maxItems": 32, "items": {"type": "object", "additionalProperties": true}}
      }
    },
    "Error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "details"],
      "properties": {
        "code": {"type": "string", "minLength": 1, "maxLength": 128},
        "message": {"type": "string", "minLength": 1, "maxLength": 512},
        "field": {"type": "string", "minLength": 1, "maxLength": 256},
        "details": {"type": "object", "additionalProperties": true}
      }
    }
  }
}
