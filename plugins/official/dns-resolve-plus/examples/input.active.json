{
  "context": {
    "task_id": "task_dns_resolve_active",
    "run_id": "run_dns_resolve_active",
    "operator": "operator",
    "workspace": "default",
    "authorization_scope": "fixture:local-only"
  },
  "target": {"type": "domain", "value": "example.com", "metadata": {}},
  "inputs": {
    "domains": ["www.example.com"],
    "findings": []
  },
  "options": {
    "mode": "active",
    "record_types": ["A", "AAAA"],
    "passive_intel": {
      "enabled": false,
      "sources": ["fixture"],
      "api_timeout_seconds": 10,
      "api_rate_limit_per_second": 1,
      "max_queries": 0,
      "allow_missing_secrets": true,
      "local_cache_file": "examples/fixture.dns.example.com.json"
    },
    "active": {
      "enabled": true,
      "resolver_mode": "public_resolver",
      "resolvers": ["1.1.1.1", "8.8.8.8"],
      "authoritative_trace": false,
      "timeout_seconds": 3,
      "concurrency": 2,
      "rate_limit_per_second": 2,
      "max_domains": 10,
      "max_queries": 20
    },
    "merge": {
      "deduplicate": true,
      "conflict_policy": "preserve_all_sources",
      "mark_source_disagreement": true,
      "confidence_strategy": "weighted_sources",
      "stale_after_days": 30
    },
    "output": {
      "include_unresolved": false,
      "include_source_details": true,
      "include_conflicts": true
    },
    "risk_acknowledged": false,
    "execution_profile": "active_safe"
  },
  "policy": {"allow_active_verify": true, "allow_high_risk": false}
}
