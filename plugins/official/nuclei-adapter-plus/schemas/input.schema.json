{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nuclei Adapter Plus Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["context", "target", "options", "policy"],
  "properties": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "run_id", "operator", "workspace", "authorization_scope"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "run_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "operator": {"type": "string", "minLength": 1, "maxLength": 128},
        "workspace": {"type": "string", "minLength": 1, "maxLength": 128},
        "authorization_scope": {"type": "string", "minLength": 3, "maxLength": 256}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value", "metadata"],
      "properties": {
        "type": {"type": "string", "enum": ["url", "domain", "report"]},
        "value": {"type": "string", "minLength": 1, "maxLength": 2048},
        "metadata": {"type": "object", "additionalProperties": true}
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "import", "templates", "output", "execution_profile"],
      "properties": {
        "mode": {"type": "string", "enum": ["fixture", "dry_run", "local_file"]},
        "import": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "file", "max_records"],
          "properties": {
            "format": {"const": "nuclei_jsonl"},
            "file": {"$ref": "#/definitions/SafeRelativePath"},
            "max_records": {"type": "integer", "minimum": 0, "maximum": 10000}
          }
        },
        "templates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed_path_prefixes", "allowed_severities", "blocked_tags", "allow_medium_or_higher"],
          "properties": {
            "allowed_path_prefixes": {
              "type": "array",
              "minItems": 1,
              "maxItems": 16,
              "items": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._/-]+$"}
            },
            "allowed_severities": {
              "type": "array",
              "minItems": 1,
              "maxItems": 5,
              "items": {"type": "string", "enum": ["info", "low", "medium", "high", "critical"]}
            },
            "blocked_tags": {
              "type": "array",
              "maxItems": 64,
              "items": {"type": "string", "minLength": 1, "maxLength": 64}
            },
            "allow_medium_or_higher": {"type": "boolean"}
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["include_request", "include_extracted_results", "include_source_details"],
          "properties": {
            "include_request": {"type": "boolean"},
            "include_extracted_results": {"type": "boolean"},
            "include_source_details": {"type": "boolean"}
          }
        },
        "execution_profile": {"type": "string", "enum": ["fixture", "offline_import"]}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allow_active_verify", "allow_high_risk", "allow_intrusive_templates"],
      "properties": {
        "allow_active_verify": {"const": false},
        "allow_high_risk": {"const": false},
        "allow_intrusive_templates": {"const": false}
      }
    }
  },
  "definitions": {
    "SafeRelativePath": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.)(?!.*\\x00).+$"}
  }
}
