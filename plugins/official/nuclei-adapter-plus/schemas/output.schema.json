{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nuclei Adapter Plus Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "target", "mode", "format", "results", "source_status", "summary", "errors", "safety"],
  "properties": {
    "source": {"const": "nuclei-adapter-plus"},
    "target": {"type": "object", "additionalProperties": true},
    "mode": {"type": "string", "enum": ["fixture", "dry_run", "local_file"]},
    "format": {"const": "nuclei_jsonl"},
    "results": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "matched_at", "template_id", "template_name", "template_severity", "sources", "confidence", "evidence"],
        "properties": {
          "type": {"const": "nuclei_result"},
          "matched_at": {"type": "string"},
          "host": {"type": ["string", "null"]},
          "ip": {"type": ["string", "null"]},
          "scheme": {"type": ["string", "null"]},
          "port": {"type": ["integer", "null"], "minimum": 0, "maximum": 65535},
          "template_id": {"type": "string"},
          "template_path": {"type": ["string", "null"]},
          "template_name": {"type": "string"},
          "template_severity": {"type": "string", "enum": ["info", "low", "medium", "high", "critical"]},
          "tags": {"type": "array", "items": {"type": "string"}},
          "cve": {"type": "array", "items": {"type": "string"}},
          "cwe": {"type": "array", "items": {"type": "string"}},
          "cvss_score": {"type": ["number", "null"], "minimum": 0, "maximum": 10},
          "references": {"type": "array", "items": {"type": "string"}},
          "sources": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "source_status": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "summary": {"type": "object", "additionalProperties": true},
    "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "safety": {"type": "object", "additionalProperties": true}
  }
}
