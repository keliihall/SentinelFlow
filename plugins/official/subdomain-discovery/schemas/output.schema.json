{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Passive Subdomain Discovery Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "root_domain", "providers", "records", "summary", "safety"],
  "properties": {
    "source": {
      "const": "passive-subdomain-discovery"
    },
    "root_domain": {
      "type": "string",
      "minLength": 3,
      "maxLength": 253
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "source_type", "record_count"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["crtsh", "hackertarget", "buffer_over"]
          },
          "status": {
            "type": "string",
            "enum": ["succeeded", "failed"]
          },
          "source_type": {
            "type": "string",
            "enum": ["embedded-fixture", "public-http"]
          },
          "record_count": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "error": {
            "type": "string",
            "maxLength": 512
          }
        }
      }
    },
    "records": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "root_domain", "sources"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 253
          },
          "root_domain": {
            "type": "string",
            "minLength": 3,
            "maxLength": 253
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["crtsh", "hackertarget", "buffer_over"]
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_subdomains", "provider_count"],
      "properties": {
        "total_subdomains": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "provider_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passive_only",
        "active_dns_queries",
        "brute_force_attempts",
        "dictionary_candidates",
        "port_scan_attempts",
        "exploit_attempts"
      ],
      "properties": {
        "passive_only": {
          "const": true
        },
        "active_dns_queries": {
          "const": 0
        },
        "brute_force_attempts": {
          "const": 0
        },
        "dictionary_candidates": {
          "const": 0
        },
        "port_scan_attempts": {
          "const": 0
        },
        "exploit_attempts": {
          "const": 0
        }
      }
    }
  }
}

