{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Passive Subdomain Discovery Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec"],
  "properties": {
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_domain", "providers", "timeout"],
      "properties": {
        "root_domain": {
          "type": "string",
          "minLength": 3,
          "maxLength": 253,
          "pattern": "^(?=.{3,253}$)(?!-)(?:[A-Za-z0-9-]{1,63}\\.)+[A-Za-z]{2,63}$"
        },
        "providers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["crtsh", "hackertarget", "buffer_over"]
          }
        },
        "timeout": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        }
      }
    }
  }
}

